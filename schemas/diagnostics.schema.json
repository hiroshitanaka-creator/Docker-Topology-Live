{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hiroshitanaka-creator/Docker-Topology-Live/schemas/diagnostics.schema.json",
  "title": "DockerTopologyLiveDiagnostics",
  "description": "Docker Topology Live local diagnostics document",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "source", "sample", "summary", "findings", "warnings"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "generatedAt":   { "type": "string" },
    "source": {
      "type": "object",
      "required": ["engine"],
      "properties": {
        "engine": { "type": "string" },
        "host":   { "type": "string" }
      }
    },
    "sample":   { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "summary": {
      "type": "object",
      "required": ["findings", "bySeverity", "byCategory"],
      "additionalProperties": false,
      "properties": {
        "findings":   { "type": "integer", "minimum": 0 },
        "bySeverity": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "properties": {
            "info":   { "type": "integer", "minimum": 0 },
            "low":    { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "high":   { "type": "integer", "minimum": 0 }
          }
        },
        "byCategory": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "properties": {
            "security":    { "type": "integer", "minimum": 0 },
            "reliability": { "type": "integer", "minimum": 0 },
            "resource":    { "type": "integer", "minimum": 0 },
            "maintenance": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "ruleId", "severity", "category",
          "target", "title", "description",
          "evidence", "recommendation", "confidence"
        ],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^finding:[0-9a-f]{12}$" },
          "ruleId":      { "type": "string" },
          "severity":    { "type": "string", "enum": ["info", "low", "medium", "high"] },
          "category":    { "type": "string", "enum": ["security", "reliability", "resource", "maintenance"] },
          "target": {
            "type": "object",
            "required": ["kind", "id", "label"],
            "additionalProperties": false,
            "properties": {
              "kind":  { "type": "string", "enum": ["container", "network"] },
              "id":    { "type": "string" },
              "label": { "type": "string" }
            }
          },
          "title":          { "type": "string" },
          "description":    { "type": "string" },
          "evidence": {
            "type": "object",
            "description": "Rule-specific evidence. For broad-bind-mount: contains 'source' (or 'sourceRedacted'+'sourceCategory' when redaction is enabled), 'destination', 'mode', 'rw'. sourceRedacted=true means the raw host path was withheld; sourceCategory gives the safe path class."
          },
          "recommendation": { "type": "string" },
          "confidence":     { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
