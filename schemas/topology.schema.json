{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hiroshitanaka-creator/Docker-Topology-Live/schemas/topology.schema.json",
  "title": "DockerTopologyLive",
  "description": "Docker Topology Live topology document",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "source", "nodes", "links"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "generatedAt":   { "type": "string" },
    "source": {
      "type": "object",
      "required": ["engine"],
      "properties": {
        "engine": { "type": "string", "enum": ["docker", "sample"] },
        "host":   { "type": "string" }
      }
    },
    "sample":   { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "kind"],
        "properties": {
          "id":     { "type": "string" },
          "label":  { "type": "string" },
          "kind":   { "type": "string", "enum": ["container", "network"] },

          "status": { "type": "string" },
          "image":  { "type": "string" },
          "state":  { "type": "string" },

          "ports": {
            "type": "array",
            "description": "Port mappings exposed by the container",
            "items": {
              "type": "object",
              "required": ["containerPort", "protocol"],
              "properties": {
                "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "hostPort":      { "type": "integer", "minimum": 1, "maximum": 65535 },
                "protocol":      { "type": "string", "enum": ["tcp", "udp", "sctp"] }
              },
              "additionalProperties": false
            }
          },

          "mounts": {
            "type": "array",
            "description": "Filesystem mounts attached to the container",
            "items": {
              "type": "object",
              "required": ["type", "destination"],
              "properties": {
                "type":        { "type": "string" },
                "destination": { "type": "string" },
                "source":      { "type": "string" },
                "mode":        { "type": "string" },
                "rw":          { "type": "boolean" }
              },
              "additionalProperties": false
            }
          },

          "labels": {
            "type": "object",
            "description": "Container labels (secret-like values are redacted)",
            "additionalProperties": { "type": "string" }
          },

          "compose_project":          { "type": "string" },
          "compose_service":          { "type": "string" },
          "compose_container_number": { "type": "string" },

          "driver":   { "type": "string" },
          "scope":    { "type": "string" },
          "internal": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "kind":   { "type": "string" },
          "label":  { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "nodes":              { "type": "integer" },
        "links":              { "type": "integer" },
        "containers":         { "type": "integer" },
        "runningContainers":  { "type": "integer" },
        "networks":           { "type": "integer" },
        "byKind":             { "type": "object" },
        "byContainerStatus":  { "type": "object" }
      }
    }
  }
}
